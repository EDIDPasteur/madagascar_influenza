# GISAID raw data — not redistributable
data/gisaid_epiflu_*

# Norosoa unpublished avian data — not redistributable
data/norosoa_avian_*.fasta

# Derived outputs in data/ are tracked (combined_metadata.tsv, madagascar_*.tsv, etc.)

# Python
__pycache__/
*.pyc
.ipynb_checkpoints/

# Quarto
/.quarto/
*_files/
env/

# Large generated outputs — excluded from GitHub due to >100 MB file size limit
# (tracked historically on GitLab; regenerate with MAFFT/IQ-TREE)
trees/*.mldist
alignments/aligned/*.fasta
alignments/benchmark/*.fasta

# IQ-TREE auxiliary outputs (checkpoints, intermediate files — not needed)
trees/*.ckp.gz
trees/*.bionj
trees/*.parstree
trees/*.uniqueseq.phy
trees/*.splits.nex
trees/*.contree
trees/*.iqtree
trees/*.log

# IQ-TREE full input FASTAs (large, regenerated by run_trees.sh)
trees/full/

# SLURM / parallel runtime logs
trees/logs/parallel_trees.log
